    ln -sfv ../run/lock $LFS/var/lock

    install -dv -m 0750 $LFS/root
    install -dv -m 1777 $LFS/tmp $LFS/var/tmp
    ln -sv /proc/self/mounts $LFS/etc/mtab
    cat > $LFS/etc/hosts << EOF
